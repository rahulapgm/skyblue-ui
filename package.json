{
  "name": "@rahulapgm/skyblue-ui",
  "version": "0.1.1",
  "description": "Skyblue UI components for GetOttam web experiences.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "author": "Rahul APGM",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rahulapgm/skyblue-ui.git"
  },
  "bugs": {
    "url": "https://github.com/rahulapgm/skyblue-ui/issues"
  },
  "homepage": "https://github.com/rahulapgm/skyblue-ui#readme",
  "keywords": [
    "react",
    "nextjs",
    "typescript",
    "tailwindcss",
    "ui",
    "components",
    "component-library",
    "design-system"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./src/*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsup && node scripts/add-use-client-directive.mjs",
    "build:preview": "vite build",
    "dev": "vite --host 0.0.0.0",
    "preview": "vite preview --host 0.0.0.0",
    "pack:check": "npm pack --dry-run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "^16.2.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@tailwindcss/vite": "^4.1.17",
    "@vitejs/plugin-react": "^5.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwindcss": "^4.1.17",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  }
}
